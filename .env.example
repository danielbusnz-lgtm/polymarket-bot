# Polymarket credentials (required for live trading, optional for paper trading)
PRIVATE_KEY=your_polygon_wallet_private_key
POLYMARKET_API_KEY=your_polymarket_api_key
POLYMARKET_SECRET=your_polymarket_secret
POLYMARKET_PASSPHRASE=your_polymarket_passphrase

# LLM API keys (minimum 3 required, Anthropic is mandatory)
# Required:
ANTHROPIC_API_KEY=

# Optional (need at least 2 of these):
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=

# News context (required)
TAVILY_API_KEY=
